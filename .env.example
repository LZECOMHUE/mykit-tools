# MyKit.tools Environment Variables
# Copy this file to .env.local and fill in the values

# Site URL
NEXT_PUBLIC_SITE_URL=https://mykit.tools

# Clerk Auth (Phase 3 - not needed for launch)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Stripe Payments (Phase 2 - not needed for launch)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Anthropic AI (Phase 5 - not needed for launch)
ANTHROPIC_API_KEY=

# Vercel KV - shareable links (Phase 3 - not needed for launch)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Google Analytics (add your GA4 measurement ID)
NEXT_PUBLIC_GA_ID=
